{
  "compileOnSave": false,
  "compilerOptions": {
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@core/*": ["./src/app/core/*"],
      "@pages/*": ["./src/app/pages/*"],
      "@environments/*": ["./src/environments/*"],
      "@/*": ["./src/app/*"],
      "@spartan-ng/helm/button": ["./src/app/shared/ui/button/src/index.ts"],
      "@spartan-ng/helm/input": ["./src/app/shared/ui/input/src/index.ts"],
      "@spartan-ng/helm/skeleton": ["./src/app/shared/ui/skeleton/src/index.ts"],
      "@spartan-ng/helm/spinner": ["./src/app/shared/ui/spinner/src/index.ts"],
      "@spartan-ng/helm/tooltip": ["./src/app/shared/ui/tooltip/src/index.ts"],
      "@spartan-ng/helm/utils": ["./src/app/shared/ui/utils/src/index.ts"],
      "@spartan-ng/helm/sheet": ["./src/app/shared/ui/sheet/src/index.ts"],
      "@spartan-ng/helm/tabs": ["./src/app/shared/ui/tabs/src/index.ts"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    }
  ]
}
